{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/swarm.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/swarm",
      "dest": "api/swarm.py"
    },
    {
      "src": "/.*",
      "dest": "/"
    }
  ]
}